 typedef void (*xkbcomp_buffer_callback)(FILE *out, void *userdata);
 
+#ifndef WIN32
+/* static-xvfb: direct-exec replacement for Popen()->execl("/bin/sh","sh","-c",cmd)
+ * (os/utils.c:1487) — a shell-less distroless host has no /bin/sh, so Popen
+ * can't run xkbcomp there and the server never finishes keyboard init (the
+ * pack's boot bar). Popen()/Pclose() are used nowhere else in this tree
+ * (verified: `grep -rln 'Popen(\|Pclose('` matches only os/utils.c, which
+ * defines them, and this file), so this adds a parallel fork/pipe/execv
+ * path used only here instead of touching the exported Popen()/Pclose()
+ * API. Mirrors Popen's own privilege-drop (setgid/setuid) and pipe
+ * plumbing; only the exec call itself differs (execv, not a shell).
+ */
+static pid_t xkbcompPid = -1;
+
+static FILE *
+PopenXkbCompDirect(char *const argv[])
+{
+    int pdes[2];
+    pid_t pid;
+    FILE *iop;
+
+    if (pipe(pdes) < 0)
+        return NULL;
+
+    if ((pid = fork()) == -1) {
+        close(pdes[0]);
+        close(pdes[1]);
+        return NULL;
+    }
+    if (pid == 0) {             /* child: xkbcomp reads stdin from the pipe */
+        if (setgid(getgid()) == -1 || setuid(getuid()) == -1)
+            _exit(127);
+        if (pdes[0] != 0) {
+            dup2(pdes[0], 0);
+            close(pdes[0]);
+        }
+        close(pdes[1]);
+        execv(argv[0], argv);
+        _exit(127);
+    }
+    close(pdes[0]);
+    if ((iop = fdopen(pdes[1], "w")) == NULL) {
+        int status;
+        pid_t reaped;
+
+        close(pdes[1]);
+        do {
+            reaped = waitpid(pid, &status, 0);
+        } while (reaped == -1 && errno == EINTR);
+        return NULL;
+    }
+    xkbcompPid = pid;
+    return iop;
+}
+
+static int
+PcloseXkbCompDirect(FILE *iop)
+{
+    int pstat;
+    pid_t pid;
+
+    fclose(iop);
+    if (xkbcompPid <= 0)
+        return -1;
+    do {
+        pid = waitpid(xkbcompPid, &pstat, 0);
+    } while (pid == -1 && errno == EINTR);
+    xkbcompPid = -1;
+    return (pid == -1) ? -1 : pstat;
+}
+#endif                          /* !WIN32 */

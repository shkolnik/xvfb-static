@@ -250,6 +250,11 @@ __glXDRIscreenCreateContext(__GLXscreen * baseScreen,
         (*core->createNewContext) (screen->driScreen, driConfig, driShare,
                                    context);
 
+    if (context->driContext == NULL) {
+        free(context);
+        return NULL;
+    }
+
     return &context->base;
 }
 
@@ -404,7 +404,8 @@ __glXDRIscreenDestroy(__GLXscreen * baseScreen)
 
     (*screen->core->destroyScreen) (screen->driScreen);
 
-    dlclose(screen->driver);
+    if (screen->driver != (void *) 1)
+        dlclose(screen->driver);
 
     __glXScreenDestroy(baseScreen);
 
@@ -471,7 +472,7 @@ __glXDRIscreenProbe(ScreenPtr pScreen)
     return &screen->base;
 
  handle_error:
-    if (screen->driver)
+    if (screen->driver && screen->driver != (void *) 1)
         dlclose(screen->driver);
 
     free(screen);

diff --git a/glx/glxdricommon.c b/glx/glxdricommon.c
--- a/glx/glxdricommon.c
+++ b/glx/glxdricommon.c
@@ -288,6 +288,9 @@ static const char dri_driver_path[] = DRI_DRIVER_PATH;
 #define __DRI_DRIVER_GET_EXTENSIONS "__driDriverGetExtensions"
 #endif
 
+extern const __DRIextension **
+__driDriverGetExtensions_swrast(void);
+
 void *
 glxProbeDriver(const char *driverName,
                void **coreExt, const char *coreName, int coreVersion,
@@ -295,12 +298,31 @@ glxProbeDriver(const char *driverName,
                void **renderExt, const char *renderName, int renderVersion)
 {
     int i;
-    void *driver;
+    void *driver = NULL;
     char filename[PATH_MAX];
     char *get_extensions_name;
     const __DRIextension **extensions = NULL;
     const char *path = NULL;
 
+    if (strcmp(driverName, "swrast") == 0) {
+        extensions = __driDriverGetExtensions_swrast();
+        if (extensions == NULL)
+            goto cleanup_failure;
+
+        for (i = 0; extensions[i]; i++) {
+            if (strcmp(extensions[i]->name, coreName) == 0 &&
+                extensions[i]->version >= coreVersion)
+                *coreExt = (void *) extensions[i];
+            if (strcmp(extensions[i]->name, renderName) == 0 &&
+                extensions[i]->version >= renderVersion)
+                *renderExt = (void *) extensions[i];
+        }
+
+        if (*coreExt == NULL || *renderExt == NULL)
+            goto cleanup_failure;
+        return (void *) 1;
+    }
+
     /* Search in LIBGL_DRIVERS_PATH if we're not setuid. */
     if (!PrivsElevated())
         path = getenv("LIBGL_DRIVERS_PATH");
@@ -387,7 +397,7 @@ glxProbeDriver(const char *driverName,
     return driver;
 
  cleanup_failure:
-    if (driver)
+    if (driver && driver != (void *) 1)
         dlclose(driver);
     *coreExt = *renderExt = NULL;
     return NULL;
diff --git a/glx/glxdriswrast.c b/glx/glxdriswrast.c
